{
  "manifest_version": 3,
  "name": "Aパレットサーチ",
  "version": "1.0",
  "description": "ページ内の任意“枠”を選択し、キーワード一致で枠を色分けする",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Aパレットサーチ"
  },
  "background": {
    "service_worker": "src/sw.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle palette"
    },
    "toggle-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Toggle picker"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/storage.js",
        "src/rulesEngine.js",
        "src/selectorGen.js",
        "src/domPicker.js",
        "src/paletteUI.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
