{
  "manifest_version": 3,
  "name": "A_パレットリビルド",
  "version": "1.2.30",
  "description": "ページ内の任意“枠”を選択し、キーワード一致で枠を色分けする",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Aパレットサーチ",
    "default_icon": {
      "16": "img/icon_16.png",
      "32": "img/icon_32.png"
    }
  },
  "background": {
    "service_worker": "src/sw.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Toggle palette"
    },
    "toggle-picker": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Toggle picker"
    }
  },
  "icons": {
    "16": "img/icon_16.png",
    "32": "img/icon_32.png",
    "48": "img/icon_48.png",
    "128": "img/icon_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/storage.js",
        "src/rulesEngine.js",
        "src/selectorGen.js",
        "src/domPicker.js",
        "src/paletteUI.js",
        "dist/palette-ui.js",
        "dist/palette-ui.css",
        "img/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
